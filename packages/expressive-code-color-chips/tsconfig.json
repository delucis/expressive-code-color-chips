{
	"include": ["src/**/*.ts"],
	"compilerOptions": {
		"allowJs": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"esModuleInterop": true,
		"exactOptionalPropertyTypes": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ESNext",
		"rootDir": "./src",
		"outDir": "./dist",

		// tsup sets baseUrl which is deprecated, so we need this
		// TODO: migrate to tsdown
		"ignoreDeprecations": "6.0"
	}
}
